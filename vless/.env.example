### НАСТРОЙКИ СЕРВЕРА REMNAWAVE PANEL ###
APP_PORT=3000
METRICS_PORT=3001

# Количество ядер процессора, используемых API (1, max или число ядер)
API_INSTANCES=1

### БАЗА ДАННЫХ (POSTGRES) ###
# Укажите случайный сложный пароль вместо "postgres_password"
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres_password
POSTGRES_DB=postgres

# Строка подключения к БД. Пароль здесь должен совпадать с POSTGRES_PASSWORD выше
DATABASE_URL="postgresql://postgres:postgres_password@remnawave-db:5432/postgres"

### REDIS/VALKEY ###
REDIS_SOCKET=/var/run/valkey/valkey.sock

### СЕКРЕТНЫЕ КЛЮЧИ (JWT) ###
# Сгенерируйте случайные строки (например, с помощью команды: openssl rand -hex 32)
JWT_AUTH_SECRET=generate_your_own_secure_key_here_auth
JWT_API_TOKENS_SECRET=generate_your_own_secure_key_here_tokens
APP_SECRET=generate_your_own_secure_key_here_app

### ДОМЕННЫЕ ИМЕНА И ДОСТУП ###
# Домен, на котором будет висеть панель администратора
PANEL_DOMAIN=panel.yourdomain.com

# Разрешить CORS (можно оставить *, либо указать ваш домен панели)
FRONT_END_DOMAIN=*

# Домен для ссылок на подписки (обычно совпадает с доменом панели с /api/sub)
SUB_PUBLIC_DOMAIN=panel.yourdomain.com/api/sub

### УВЕДОМЛЕНИЯ В ТЕЛЕГРАМ (Опционально) ###
IS_TELEGRAM_NOTIFICATIONS_ENABLED=false
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_NOTIFY_USERS=your_chat_id
TELEGRAM_NOTIFY_NODES=your_chat_id
TELEGRAM_NOTIFY_CRM=your_chat_id
TELEGRAM_NOTIFY_SERVICE=your_chat_id
TELEGRAM_NOTIFY_TBLOCKER=your_chat_id

### ДОКУМЕНТАЦИЯ API (Опционально) ###
IS_DOCS_ENABLED=false
METRICS_USER=admin
METRICS_PASS=admin_password
